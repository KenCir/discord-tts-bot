{
	"id": "default",
	"data": {
		"\\s+": {
			"flags": "gi",
			"replace": "、"
		},
		"\\n": {
			"flags": "gi",
			"replace": "、"
		},
		"\\[.*\\]\\((?<url>https?:\\/\\/.*)\\)": {
			"flags": "gi",
			"replace": "マスクされた$<url>、"
		},
		"https?:\\/\\/(?:.*\\.)?youtu(?:be\\.com|\\.be)\\/\\S+": {
			"flags": "gi",
			"replace": "ようつべのリンク、"
		},
		"https?:\\/\\/(?:.*\\.)?(?:twitter|x)\\.com\\/\\S+": {
			"flags": "gi",
			"replace": "X(旧ツイッター)のリンク、"
		},
		"(?:https?:\\/\\/)?(?:.*\\.)?discord.*\\.(?:gg|com|net)\\/\\S+": {
			"flags": "gi",
			"replace": "ディスコードのリンク、"
		},
		"https?:\\/\\/(?:.*\\.)?nicovideo\\.jp\\/\\S+": {
			"flags": "gi",
			"replace": "ニコ動のリンク、"
		},
		"https?:\\/\\/(?:.*\\.)?github\\.com\\/\\S+": {
			"flags": "gi",
			"replace": "ギットハブのリンク、"
		},
		"https?:\\/\\/\\S+": {
			"flags": "gi",
			"replace": "リンク省略、"
		},
		"<a?:.*?:\\d+>": {
			"flags": "gi",
			"replace": ""
		},
		"<@!?.*?>": {
			"flags": "gi",
			"replace": ""
		},
		"<#.*?>": {
			"flags": "gi",
			"replace": ""
		},
		"<@&.*?>": {
			"flags": "gi",
			"replace": ""
		},
		"#": {
			"flags": "gi",
			"replace": ""
		},
		"(?:\\*|\\*\\*|_|__|~~)(?<text>.*?)(?:\\*|\\*\\*|_|__|~~)": {
			"flags": "gi",
			"replace": "$<text>"
		},
		">|>>>": {
			"flags": "gi",
			"replace": "引用、"
		},
		"\\|\\|.*?\\|\\|": {
			"flags": "gi",
			"replace": "ネタバレメッセージ、"
		},
		"[\\u{1F300}-\\u{1F5FF}\\u{1F900}-\\u{1F9FF}\\u{1F600}-\\u{1F64F}\\u{1F680}-\\u{1F6FF}\\u{2600}-\\u{26FF}\\u{2700}-\\u{27BF}\\u{1F1E6}-\\u{1F1FF}\\u{1F191}-\\u{1F251}\\u{1F004}\\u{1F0CF}\\u{1F170}-\\u{1F171}\\u{1F17E}-\\u{1F17F}\\u{1F18E}\\u{3030}\\u{2B50}\\u{2B55}\\u{2934}-\\u{2935}\\u{2B05}-\\u{2B07}\\u{2B1B}-\\u{2B1C}\\u{3297}\\u{3299}\\u{303D}\\u{00A9}\\u{00AE}\\u{2122}\\u{23F3}\\u{24C2}\\u{23E9}-\\u{23EF}\\u{25B6}\\u{23F8}-\\u{23FA}]": {
			"flags": "gu",
			"replace": ""
		},
		"(?:```|`).*?(?:```|`)": {
			"flags": "gis",
			"replace": "コードブロック、"
		},
		"ww+|ｗｗ+": {
			"flags": "gi",
			"replace": "わらわら、"
		}
	}
}
